# ============================================================
# Multi-Shop E-Commerce Platform - Docker Environment Variables
# ============================================================

# MySQL
MYSQL_ROOT_PASSWORD=123456
MYSQL_PORT=3307

# Redis
REDIS_PORT=6379

# Nacos
NACOS_AUTH_USERNAME=nacos
NACOS_AUTH_PASSWORD=nacos
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_GRPC_CLUSTER_PORT=9849

# Seata
SEATA_PORT=8091
SEATA_CONSOLE_PORT=7091

# Backend Service Ports
AUTH_SERVICE_PORT=8081
SHOP_SERVICE_PORT=8082
COUPON_SERVICE_PORT=8083
ORDER_SERVICE_PORT=8084
INVENTORY_SERVICE_PORT=8085
PAYMENT_SERVICE_PORT=8086
GATEWAY_SERVICE_PORT=8088

# Frontend
FRONTEND_PORT=80

# JWT
JWT_SECRET=shop-coupon-platform-jwt-secret-key-2025
